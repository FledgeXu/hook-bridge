{
    "hooks": {
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run python .codex/hooks/static_checks.py",
                        "statusMessage": "正在执行结束前静态检查..."
                    }
                ]
            },
            {
                "matcher": ".*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 .codex/hooks/auto_review.py",
                        "statusMessage": "正在执行自动代码评审..."
                    }
                ]
            }
        ]
    }
}
